DATABASE_URL=sqlite:///literadb.sqlite
FLASK_SECRET=change-me
UPLOAD_FOLDER=uploads
OCR_PROVIDER=yandex

VISION_API_KEY=
VISION_API_URL=
LLM_MODEL=
SA_KEY_PATH=sa-key.json

TESSERACT_CMD=
TESSERACT_LANG=rus+eng
TESSERACT_PSM=6

EASYOCR_LANGS=ru,en
EASYOCR_GPU=false

TROCR_MODEL=microsoft/trocr-base-handwritten

PADDLEOCR_LANG=cyrillic
PADDLEOCR_USE_ANGLE_CLS=true

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
VLM_OCR_PROMPT=Transcribe this Russian handwritten text exactly. Preserve line breaks. Return only the transcribed text.
VLM_OCR_MAX_TOKENS=2048

QWEN25_VL_7B_MODEL=qwen/qwen2.5-vl-7b-instruct
QWEN25_VL_32B_MODEL=qwen/qwen2.5-vl-32b-instruct
QWEN25_VL_72B_MODEL=qwen/qwen2.5-vl-72b-instruct
GEMMA3_VISION_MODEL=google/gemma-3-27b-it
INTERNVL_MODEL=opengvlab/internvl3-14b
MINICPM_V_MODEL=openbmb/minicpm-v-2.6

FLORENCE2_MODEL=microsoft/Florence-2-base
FLORENCE2_TASK_PROMPT=<OCR>
FLORENCE2_MAX_TOKENS=1024
